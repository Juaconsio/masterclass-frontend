---
import { Image } from 'astro:assets';
import Logo from '/src/assets/logo.svg';
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
import waUrl, { phoneNumber } from '@/lib/waMessage';
---

<footer class="text-neutral-content bg-black">
  <div class="container mx-auto px-4 py-8 sm:px-6 sm:py-12">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 md:grid-cols-4">
      <!-- Brand / About -->
      <div class="space-y-3 sm:space-y-4">
        <a href="/" class="inline-flex items-center gap-2 sm:gap-3">
          <Image src={Logo} alt="SalvaRamos Logo" class="h-18 w-auto sm:h-22" />
        </a>
        <p class="text-sm text-balance sm:text-base">
          Empoderamos a la próxima generación de ingenieros con cursos claros, prácticos y
          acompañamiento cercano.
        </p>
      </div>

      <!-- Navegación -->
      <nav aria-labelledby="footer-nav-title" class="space-y-3 sm:space-y-4">
        <h3 id="footer-nav-title" class="text-base font-semibold sm:text-lg">Navegación</h3>
        <ul class="space-y-1.5 text-sm sm:space-y-2 sm:text-base">
          <li><a class="link link-hover link-white" href="/">Inicio</a></li>
          <li><a class="link link-hover link-white" href="/cursos">Cursos</a></li>
          <li><a class="link link-hover link-white" href="/nosotros">Sobre nosotros</a></li>
          <li>
            <a class="link link-hover link-white" href="/nosotros#faq">Preguntas frecuentes</a>
          </li>
          <li><a class="link link-hover link-white" href="/#contact">Contacto</a></li>
        </ul>
      </nav>

      <!-- Contacto -->
      <div aria-labelledby="footer-contact-title" class="space-y-3 sm:space-y-4">
        <h3 id="footer-contact-title" class="text-base font-semibold sm:text-lg">Contacto</h3>
        <ul class="space-y-1.5 text-sm sm:space-y-2 sm:text-base">
          <li>
            <a
              class="link link-hover text-base-100/90 hover:text-primary break-all"
              href="mailto:salvaramos.ing@gmail.com">salvaramos.ing@gmail.com</a
            >
          </li>
          <li>
            <a
              class="link link-hover text-base-100/90 hover:text-primary"
              href={waUrl}
              rel="noopener"
              target="_blank">{phoneNumber}</a
            >
          </li>
          <li>
            <a
              class="link link-hover text-base-100/90 hover:text-primary"
              href="https://instagram.com/salvaramos_ing"
              rel="noopener"
              target="_blank">@salvaramos_ing</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="divider my-6 sm:my-8"></div>

    <!-- Legal / Credits -->
    <div class="flex flex-col items-center justify-between gap-3 sm:gap-4 md:flex-row">
      <p class="text-center text-xs sm:text-sm md:text-left">
        © {year} SalvaRamos. Todos los derechos reservados.
      </p>
      <p class="text-sm">
        Powered by <Icon name="mdi:rabbit" class="inline-block" size={16} /> conejo.dev
      </p>
    </div>
  </div>
</footer>
