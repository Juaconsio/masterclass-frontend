---
import { pilares } from '@/data/pilares';
import PilarCard from './PilarCard.astro';
---

<section id="pilares" class="py-20 sm:py-24 md:py-28">
  <div class="container mx-auto px-4 sm:px-6">
    <header class="mx-auto mb-12 max-w-3xl text-center sm:mb-14 md:mb-16" data-usal="fade-up">
      <p class="text-primary mb-3 text-xs font-semibold tracking-[0.2em] uppercase sm:text-sm">
        Pilares
      </p>
      <h2
        class="text-base-content mb-3 text-3xl font-bold text-balance sm:text-4xl md:text-5xl"
      >
        Los <span class="font-gebuk text-primary">valores</span> que guían nuestro trabajo
      </h2>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 sm:gap-8 lg:gap-10">
      {pilares.map((item) => <PilarCard item={item} />)}
    </div>
  </div>
</section>
