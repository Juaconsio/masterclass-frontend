---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Logo from '/src/assets/imagotipo.svg';

const links = [
  { href: '/', label: 'Inicio', icon: 'mdi:home' },
  { href: '/courses', label: 'Cursos', icon: 'mdi:book' },
  // { href: '/nosotros', label: 'Nosotros', icon: 'mdi:account-group' }, // Oculto temporalmente
  // { href: '/#contact', label: 'Contacto', icon: 'mdi:contact-mail' },
];

const current = Astro.url.pathname + (Astro.url.hash ?? '');
const isActive = (href: string) => href === current;
---

<!-- Navbar principal: estructura DaisyUI navbar-start | navbar-center | navbar-end -->
<nav
  class="navbar h-navbar bg-accent/80 border-base-300 fixed top-0 z-50 border-b px-3 backdrop-blur sm:px-4 md:px-6 lg:px-8"
>
  <!-- navbar-start: menú (móvil) + logo (desktop) -->
  <div class="navbar-start">
    <label
      for="main-drawer"
      aria-label="Abrir menú"
      class="btn btn-square btn-ghost btn-sm sm:btn-md lg:hidden"
    >
      <Icon name="mdi:menu" size={28} class="sm:h-8 sm:w-8" />
    </label>
    <a
      href="/"
      class="hidden items-center gap-1 px-1 text-lg font-bold tracking-wide normal-case hover:bg-transparent sm:gap-2 sm:px-2 sm:text-xl lg:flex lg:px-0"
    >
      <Image src={Logo} alt="Salva Ramos Logo" class="h-12 w-auto" />
    </a>
  </div>

  <!-- navbar-center: logo (móvil, centrado) + enlaces (desktop) -->
  <div class="navbar-center flex w-full flex-1 justify-center lg:flex-initial">
    <a href="/" class="flex min-w-28 items-center px-1 lg:hidden">
      <Image src={Logo} alt="Salva Ramos Logo" class="h-12 w-auto" />
    </a>
    <ul class="menu menu-horizontal hidden gap-1 px-1 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              data-navlink
              data-current={isActive(link.href) ? 'page' : undefined}
              href={link.href}
              class="text-sm font-medium"
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- navbar-end: Iniciar sesión + CTA -->
  <div class="navbar-end gap-1 sm:gap-2">
    <a
      href="/ingresar"
      aria-label="Iniciar Sesión"
      class="btn btn-ghost btn-sm hidden lg:inline-flex"
    >
      Iniciar Sesión
    </a>
    <a
      href="/courses"
      aria-label="Ver cursos"
      class="btn btn-primary btn-sm sm:btn-md rounded-xl sm:px-4"
    >
      Empezar <span class="hidden sm:inline">ahora</span>
    </a>
  </div>
</nav>

<!-- Drawer: Menú principal (móvil) -->
<div class="drawer z-60">
  <input id="main-drawer" type="checkbox" class="drawer-toggle" />
  <div class="drawer-content"></div>
  <div class="drawer-side">
    <label for="main-drawer" aria-label="Cerrar menú" class="drawer-overlay"></label>
    <aside
      class="bg-base-200/95 border-base-300/50 flex min-h-full w-72 flex-col border-r backdrop-blur-sm sm:w-80"
    >
      <header
        class="border-base-300/50 flex shrink-0 items-center gap-3 border-b px-5 py-4 sm:px-6 sm:py-5"
      >
        <a
          href="/"
          class="flex items-center gap-2"
          onclick="document.getElementById('main-drawer').click()"
        >
          <Image src={Logo} alt="" class="h-10 w-auto sm:h-11" aria-hidden="true" />
        </a>
      </header>
      <nav
        class="flex-1 overflow-y-auto px-3 py-4 sm:px-4 sm:py-5"
        aria-label="Navegación principal"
      >
        <p
          class="text-base-content/60 mb-3 px-2 text-xs font-semibold tracking-wider uppercase sm:mb-4 sm:text-sm"
        >
          Navegación
        </p>
        <ul class="menu gap-1 p-0" role="list">
          {
            links.map((link) => {
              const active = isActive(link.href);
              return (
                <li class="[&>a]:rounded-xl">
                  <a
                    data-navlink
                    data-current={active ? 'page' : undefined}
                    href={link.href}
                    class={`flex items-center gap-3 py-3 pr-4 pl-3 text-base font-medium transition-colors sm:py-3.5 sm:pl-4 sm:text-[15px] ${active ? 'bg-primary/10 text-primary' : 'text-base-content hover:bg-base-300/60 hover:text-base-content'}`}
                    aria-current={active ? 'page' : undefined}
                    onclick="document.getElementById('main-drawer').click()"
                  >
                    <span
                      class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-lg sm:h-10 sm:w-10 ${active ? 'bg-primary/20' : 'bg-base-300/70'}`}
                      aria-hidden="true"
                    >
                      <Icon
                        name={link.icon}
                        size={22}
                        class={active ? 'text-primary' : 'text-base-content/80'}
                      />
                    </span>
                    <span>{link.label}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
      <footer class="border-base-300/50 shrink-0 border-t px-4 py-4 sm:px-5 sm:py-5">
        <a
          href="/ingresar"
          aria-label="Iniciar Sesión"
          class="btn btn-primary btn-block sm:btn-lg gap-2 rounded-xl"
          onclick="document.getElementById('main-drawer').click()"
        >
          <Icon name="mdi:login" size={20} class="shrink-0" />
          <span>Iniciar Sesión</span>
        </a>
      </footer>
    </aside>
  </div>
</div>
