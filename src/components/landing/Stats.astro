---
import { Icon } from 'astro-icon/components';
---

<div>
  <!-- Stats Section -->
  <section
    class="flex flex-col items-center justify-around gap-6 rounded-2xl px-4 py-8 sm:gap-8 sm:px-6 sm:py-12 lg:pt-4 lg:pb-8"
  >
    <ul
      class="grid w-full max-w-6xl grid-cols-2 gap-8 sm:gap-10 lg:grid-cols-4 lg:gap-4"
      data-usal="split-item split-fade-r split-delay-100"
    >
      <li class="flex items-center justify-center gap-3 sm:gap-4">
        <div class="flex h-full items-center gap-3 py-2 sm:gap-4 sm:py-4">
          <Icon name="mdi:school" size={48} class="text-primary sm:h-16 sm:w-16" />
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">
            +<span data-usal="count-[6]">6</span>{' '} años
          </div>
          <div class="w-28 text-sm sm:w-32 sm:text-base">de experiencia</div>
        </div>
      </li>

      <li class="flex items-center justify-center gap-3 sm:gap-4">
        <div class="flex h-full items-center gap-3">
          <Icon name="mdi:user-group" size={48} class="text-primary sm:h-16 sm:w-16" />
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">
            + <span data-usal="count-[750]">750</span>
          </div>
          <div class="w-28 text-sm sm:w-32 sm:text-base">Estudiantes acompañados</div>
        </div>
      </li>

      <li class="flex items-center justify-center gap-3 sm:gap-4">
        <div class="flex h-full items-center gap-3">
          <Icon name="mdi:refresh-circle" size={48} class="text-primary sm:h-16 sm:w-16" />
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">~<span data-usal="count-[80]">80</span>%</div>
          <div class="w-28 text-sm sm:w-32 sm:text-base">Volvió a confiar en nosotros</div>
        </div>
      </li>
      <li class="flex items-center justify-center gap-3 sm:gap-4">
        <div class="flex h-full items-center gap-3">
          <Icon name="mdi:book-open-variant" size={48} class="text-primary sm:h-16 sm:w-16" />
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">+<span data-usal="count-[10]">10</span></div>
          <div class="w-28 text-sm sm:w-32 sm:text-base">Cursos STEM disponibles</div>
        </div>
      </li>
    </ul>
  </section>
</div>
