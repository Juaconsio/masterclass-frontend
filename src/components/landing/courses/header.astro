---
import { DEPARTMENT_COLORS, LEVEL_COLORS, DEPARTMENT_ICONS } from '@/types/course';
import type { CourseListingData } from '@/types/course';
import { Icon } from 'astro-icon/components';

const { course } = Astro.props as { course: CourseListingData };

const levelClass = LEVEL_COLORS[course.level] ?? '';
const deptClass = DEPARTMENT_COLORS[course.department] ?? '';
---

<header class="course-header relative mt-18 min-h-[280px] w-full overflow-hidden rounded-lg">
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={course.image
      ? `background-image: url(${course.image})`
      : 'background: linear-gradient(135deg, var(--p) 0%, var(--pf) 100%)'}
    aria-hidden="true"
  >
  </div>
  <div class="course-header-mask absolute inset-0" aria-hidden="true"></div>
  <div class="relative flex min-h-[280px] flex-col justify-between p-4 text-white sm:p-6 md:p-8">
    <div class="flex items-start justify-between gap-4">
      <a
        href="/cursos"
        class="btn btn-ghost btn-sm gap-2 text-white hover:bg-white/20"
        aria-label="Volver a todos los cursos"
      >
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        <span class="hidden sm:inline">Volver a cursos</span>
      </a>
    </div>
    <div class="space-y-3">
      <h1 class="text-2xl font-bold drop-shadow-md sm:text-3xl md:text-4xl lg:text-5xl">
        {course.title}
      </h1>
      <div class="flex flex-wrap gap-2">
        <span class="badge badge-lg border-0 font-mono font-bold opacity-95">
          {course.acronym}
        </span>
        <span class={`badge badge-lg border-0 font-mono text-xs opacity-95 ${levelClass}`}>
          {course.level}
        </span>
        <span class={`badge badge-lg border-0 font-mono text-xs opacity-95 ${deptClass}`}>
          {DEPARTMENT_ICONS[course.department]}
          <span class="ml-1">{course.department}</span>
        </span>
      </div>
    </div>
  </div>
</header>

<style>
  .course-header-mask {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.4) 40%,
      transparent 100%
    );
  }
</style>
