---
import { Icon } from 'astro-icon/components';
import waUrl from '@/lib/waMessage';
---

<div class="py-12 sm:py-16 md:py-24">
  <section
    class="bg-primary text-primary-content flex min-h-64 flex-col items-center justify-center gap-3 rounded-2xl p-4 text-center sm:min-h-80 sm:rounded-3xl sm:p-6 md:h-96 md:rounded-4xl md:p-8"
  >
    <h2 class="mb-2 text-3xl font-bold sm:text-4xl md:text-5xl lg:text-6xl">
      Salva <span class="text-primary bg-accent font-gebuk inline-block rounded-xl px-4 py-2">
        tu semestre</span
      >
    </h2>
    <p class="text-base sm:text-lg md:text-xl">
      Únete a cientos de estudiantes que ya están estudiando de forma inteligente.
    </p>
    <div class="mt-4 flex w-full flex-col gap-3 sm:mt-6 sm:w-auto sm:flex-initial sm:flex-row">
      <a href="/ingresar" class="btn btn-ghost btn-accent sm:btn-xl w-full rounded-full sm:w-auto">
        Empezar ahora
      </a>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost btn-accent sm:btn-xl w-full rounded-full sm:w-auto"
      >
        <Icon name="mdi:whatsapp" size={24} aria-hidden="true" />
        Habla con nosotros
      </a>
    </div>
  </section>
</div>
