---
import TeamCard from './TeamCard.astro';

interface Props {
  members: { name: string; image: string }[];
}

const { members } = Astro.props;
---

<TeamCard
  titlePrefix="#"
  title="Equipo"
  titleSuffix="Docente"
  description="Ex ayudantes con las mejores herramientas para tu aprendizaje"
  members={members}
  ariaLabel="Ver todo el equipo de profesores"
  showIsotipo={true}
  variant="accent"
/>
