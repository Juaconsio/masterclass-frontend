---
import TeamCard from './TeamCard.astro';

interface Props {
  members: { name: string; image: string }[];
  extraCount?: number;
}

const { members, extraCount = 2 } = Astro.props;
---

<TeamCard
  titlePrefix="#"
  title="Equipo"
  titleSuffix="Marketing"
  description="Estrategia y comunicación para conectar con estudiantes"
  members={members}
  extraCount={extraCount}
  ariaLabel="Ver todo el equipo de marketing"
  showIsotipo={true}
  variant="neutral"
/>
