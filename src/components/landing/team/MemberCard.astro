---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role: string;
  image: ImageMetadata;
  degree?: string;
  variant?: 'neutral' | 'accent' | 'secondary';
}

const { name, role, image, degree, variant = 'neutral' } = Astro.props;
---

<a
  href="#equipo"
  class={`group relative flex min-w-0 flex-col overflow-hidden rounded-2xl transition-all hover:shadow-xl bg-${variant}`}
>
  <div class="relative aspect-[3/4] overflow-hidden">
    <Image
      src={image}
      alt={name}
      class={`h-full w-full object-cover object-top transition-all duration-300 group-hover:scale-105`}
      format="svg"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent">
    </div>
    <div class={`absolute right-0 bottom-0 left-0 pt-4`}>
      <div class={`rounded-lg px-3 py-2 shadow-lg bg-black/50`}>
        <p class={`font-display font-bold text-white`}>{name} - {role}</p>
        {degree && <p class="text-sm text-white/70">{degree}</p>}
      </div>
    </div>
  </div>
  <div class="absolute top-3 right-3 text-white/90">
    <Icon
      name="mdi:arrow-top-right"
      class={`transition-all duration-300 group-hover:-translate-x-1 group-hover:translate-y-1`}
      size={24}
      aria-hidden="true"
    />
  </div>
</a>
