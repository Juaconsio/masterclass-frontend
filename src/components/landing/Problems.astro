---
import { Icon } from 'astro-icon/components';

const cards = [
  {
    title: 'No logras manter el ritmo de clases',
    description: 'El profesor avanza rápido, la materia y las dudas se acumulan cada clase.',
    icon: 'mdi:run-fast',
    bgClass: 'bg-primary/10',
    iconClass: 'text-primary',
  },
  {
    title: 'No sabes cómo enfrentar la prueba',
    description: 'No es claro qué es importante para la evaluación.',
    icon: 'mdi:target-arrow',
    bgClass: 'bg-secondary/10',
    iconClass: 'text-secondary',
  },
  {
    title: 'No encuentras los recursos',
    description: 'No hay guías, material o videos apropiados que te ayuden a estudiar.',
    icon: 'mdi:archive-search',
    bgClass: 'bg-info/10',
    iconClass: 'text-info',
  },
  {
    title: 'No encuentras apoyo',
    description: 'Ni el profesor ni el ayudante ni compañeros disponibles para ayudarte.',
    icon: 'mdi:user-help',
    bgClass: 'bg-neutral/10',
    iconClass: 'text-neutral',
  },
];
---

<section id="problems" class="px-4 py-12 sm:px-6 sm:py-16 md:py-20">
  <div class="mx-auto max-w-6xl text-center">
    <h2 class="font-display mb-4 text-3xl font-bold sm:mb-6 sm:text-4xl md:text-5xl">
      La universidad no debería ser una <span class="text-error">pesadilla</span>
    </h2>
    <p class="text-base-content/70 mx-auto max-w-2xl text-base sm:text-lg">
      Identificamos los dolores reales que te quitan el sueño y los resolvemos de raíz.
    </p>

    <ul
      class="mt-10 grid gap-6 sm:mt-14 sm:grid-cols-2 lg:grid-cols-4"
      data-usal="split-item split-fade-r split-delay-100"
    >
      {
        cards.map(({ title, description, icon, bgClass, iconClass }) => (
          <li
            class={`flex flex-col items-center rounded-2xl p-6 text-center sm:rounded-3xl sm:p-8 ${bgClass}`}
          >
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center sm:h-14 sm:w-14 ${iconClass}`}
            >
              <Icon name={icon} size={32} class="h-8 w-8 sm:h-9 sm:w-9" />
            </div>
            <h3 class="font-display mb-2 text-lg font-bold sm:text-xl">{title}</h3>
            <p class="text-base-content/70 text-sm sm:text-base">{description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
