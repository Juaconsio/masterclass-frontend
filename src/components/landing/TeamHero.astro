---
interface Props {
  backgroundImage?: string;
}
import teamImage from '/src/assets/teamHero.png';

const { backgroundImage = teamImage.src } = Astro.props;
---

<div
  class="sm:min-h-hero relative flex min-h-[50vh] w-full flex-col"
  style={backgroundImage
    ? `background-image: url(${backgroundImage}); background-size: cover; background-position: center;`
    : ''}
>
  <div
    class="absolute inset-0 z-0 bg-gradient-to-b from-transparent via-black/10 to-black/20 to-75% backdrop-blur-[2px]"
    aria-hidden="true"
  >
  </div>
  <section
    class="hero relative z-10 flex flex-col items-center justify-center px-4 py-16 text-center sm:px-6 sm:py-20 md:px-8 md:py-24"
  >
    <h1
      class="font-display mb-4 text-4xl font-bold text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.7)] sm:mb-6 md:text-5xl lg:text-6xl"
    >
      De estudiantes para estudiantes
    </h1>
    <p
      class="max-w-4xl text-center text-base text-pretty text-white/95 drop-shadow-[0_1px_4px_rgba(0,0,0,0.6)] sm:text-lg md:text-xl lg:text-2xl"
    >
      Combinamos excelencia académica con cercanía humana. No solo son ayudantes expertos, fuimos
      estudiantes y seremos tu compañía en esta etapa.
    </p>
  </section>
</div>
