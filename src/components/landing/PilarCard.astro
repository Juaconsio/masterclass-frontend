---
import { Icon } from 'astro-icon/components';
import type { Pilar } from '@/data/pilares';

interface Props {
  item: Pilar;
  compact?: boolean;
  list?: boolean;
  grid?: boolean;
}

const { item, compact = false, list = false, grid = false } = Astro.props;

const accentCardStyles: Record<string, string> = {
  primary: 'bg-accent/10 text-primary-content',
};

const accentIconStyles: Record<string, string> = {
  primary: 'text-primary-content',
  secondary: 'text-secondary-content',
  info: 'text-info-content',
  success: 'text-success-content',
};

const accent = item.listAccent ?? 'primary';
---

<article
  class={`relative flex min-w-0 w-full overflow-hidden rounded-2xl ${list ? `flex-row items-center gap-3 p-3 sm:p-4 ${accentCardStyles[accent] ?? accentCardStyles.primary}` : ''} ${grid ? `flex-col items-center justify-center gap-1.5 p-2 sm:gap-2 sm:p-3 md:p-4 ${accentCardStyles[accent] ?? accentCardStyles.primary}` : ''} ${!list && !grid ? 'flex-col bg-white shadow-lg shadow-base-content/5' : ''} ${!list && !grid && compact ? 'p-3 sm:p-4' : ''} ${!list && !grid && !compact ? 'p-6 sm:p-8' : ''}`}
>
  {
    grid ? (
      <>
        <div
          class={`flex shrink-0 ${accentIconStyles[accent] ?? accentIconStyles.primary}`}
          aria-hidden="true"
        >
          <Icon name={item.icon} size={40} class="h-10 w-10 sm:h-12 sm:w-12 md:h-14 md:w-14" />
        </div>
        <h3
          class={`line-clamp-2 min-w-0 text-center text-[10px] leading-tight font-medium sm:text-xs md:text-sm ${accentIconStyles[accent] ?? accentIconStyles.primary}`}
        >
          {item.title}
        </h3>
      </>
    ) : (
      <>
        <div
          class={`pointer-events-none absolute -right-6 -bottom-10 z-0 ${item.iconColor} ${compact ? 'h-20 w-20 sm:h-24 sm:w-24' : 'h-32 w-32 sm:h-40 sm:w-40'}`}
          aria-hidden="true"
        >
          <Icon name={item.icon} size={compact ? 96 : 160} class="h-full w-full" />
        </div>
        <div class="relative z-10 flex flex-col">
          <h3
            class={`text-complement font-bold ${compact ? 'mb-0.5 text-xs sm:text-sm' : 'mb-3 text-xl sm:text-2xl'}`}
          >
            {item.title}
          </h3>
          {item.desc && (
            <p
              class={`text-base-content leading-relaxed ${compact ? 'line-clamp-2 text-[10px] sm:text-xs' : 'text-sm sm:text-base'}`}
            >
              {item.desc}
            </p>
          )}
        </div>
      </>
    )
  }
</article>
