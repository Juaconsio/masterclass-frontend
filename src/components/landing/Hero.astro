---
import { Icon } from 'astro-icon/components';
import Stats from './Stats.astro';
import waUrl from '@/lib/waMessage';
---

<div class="h-hero flex w-full flex-col gap-12">
  <section
    class="hero relative z-10 flex flex-col items-center justify-center px-4 text-center sm:px-6 md:px-8"
  >
    <div
      class="bg-primary/10 text-primary relative z-10 mb-8 inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm font-medium"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="bg-primary absolute inline-flex h-full w-full animate-ping rounded-full opacity-75 motion-reduce:animate-none"
        ></span>
        <span class="bg-primary relative inline-flex h-2 w-2 rounded-full"></span>
      </span>
      Semestre 01-2026
    </div>
    <h1 class="mb-4 text-4xl font-bold sm:mb-6 md:text-5xl lg:text-6xl xl:text-7xl">
      No dejes que un ramo <br />
      <span class="text-primary relative">atrase tu carrera</span>
    </h1>

    <p
      class="mb-6 max-w-4xl text-center text-base text-pretty sm:mb-8 sm:text-lg md:text-xl lg:text-2xl"
    >
      Únete a la comunidad de estudiantes y profesores expertos. Clases en vivo, material de estudio
      y resolución de dudas para que apruebes tus ramos.
    </p>

    <div class="flex w-full flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
      <a
        href="/cursos"
        class="btn sm:btn-wide sm:btn-lg btn-primary font-display h-auto w-full border-none px-6 py-3 text-base sm:px-8 sm:py-4 sm:text-lg"
      >
        Salva tu semestre!
      </a>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn sm:btn-wide sm:btn-lg link-hover btn-link h-auto w-full border-0 px-2 py-3 sm:px-4 sm:py-4 sm:text-lg"
      >
        Habla con nosotros
        <Icon name="mdi:whatsapp" size={24} class="text-primary" />
      </a>
    </div>
    <a href="#reviews" class="link-hover text-base-content/70 mt-2 text-sm sm:mt-3">
      ¿Dudas? Lee los testimonios de estudiantes de semestres anteriores
    </a>
  </section>
  <Stats />
</div>
