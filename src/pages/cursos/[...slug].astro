---
import { getCollection, getEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import NavBar from '@components/landing/Navbar.astro';
import Header from '@components/landing/courses/header.astro';
import CourseHelpCard from '@components/landing/courses/CourseHelpCard.astro';
import CoursePlansSection from '@components/landing/courses/CoursePlansSection.astro';
import CourseSessionsTab from '@/components/landing/islands/CourseSessionsTab';
import CourseProfessorsSection from '@/components/landing/islands/CourseProfessorsSection';
import { getPublicCourseCatalog } from '@/lib/courseCatalog';
import { fetchPublicCoursePlans } from '@/client/publicCourses';
import type { CourseListingData } from '@/types/course';
import { resolveTeamImageForImg } from '@/lib/teamAssets';

export const prerender = false;

const { slug } = Astro.params;
const catalog = await getPublicCourseCatalog({ includeInactive: true });
const catalogCourse = catalog.find((entry) => entry.slug === slug);
let contentEntry = null;
let descriptionEntry = null;

try {
  contentEntry = await getEntry('courseContents', slug as string);
} catch (error) {
  console.error('Error fetching content entry:', error);
  contentEntry = null;
}
try {
  descriptionEntry = await getEntry('courseDescriptions', slug as string);
} catch (error) {
  console.error('Error fetching description entry:', error);
  descriptionEntry = null;
}

const course = (catalogCourse?.data ?? null) as CourseListingData | null;

if (!course) {
  if (catalog.length === 0) {
    return Astro.redirect('/cursos');
  }
  return Astro.redirect('/404');
}

const contentRender = contentEntry ? await contentEntry.render() : null;
const descriptionRender = descriptionEntry ? await descriptionEntry.render() : null;
const relatedCourses = catalog
  .filter((entry) => entry.data.department === course.department && entry.slug !== slug)
  .slice(0, 3);

const plansResponse = await fetchPublicCoursePlans(course.acronym);
const coursePlans = plansResponse?.plans ?? [];

const teamEntries = await getCollection('team');
const teamProfilesPayload = teamEntries
  .filter((e) => e.data.professorId != null)
  .map((e) => ({
    professorId: e.data.professorId as number,
    slug: e.slug,
    name: e.data.name,
    degree: e.data.degree,
    imageSrc: resolveTeamImageForImg(e.data.image),
  }));
---

<Layout title={`${course.acronym} - ${course.title}`}>
  <div>
    <NavBar />
    <section class="min-h-screen">
      <div class="container mx-auto flex flex-col gap-4 px-4 py-6 md:px-6">
        <Header course={course} />

        <CoursePlansSection
          course={{ acronym: course.acronym, title: course.title }}
          plans={coursePlans}
        />
        <div class="grid grid-cols-1 gap-8 pt-8 md:grid-cols-7">
          <div class="flex flex-col gap-6 md:col-span-5">
            <div class="card bg-base-100 overflow-hidden shadow-xl">
              <div class="card-body p-0">
                <div
                  class="card-title border-base-300/80 bg-base-200/65 !mb-0 border-b px-3 py-2.5 sm:px-5 sm:py-3"
                >
                  <div
                    role="tablist"
                    class="tabs tabs-border w-full border-0 border-b-0 bg-transparent p-0"
                  >
                    <input
                      type="radio"
                      name="course_tabs"
                      role="tab"
                      class="tab text-base font-bold tracking-tight"
                      aria-label="Descripción del Curso"
                      checked
                    />
                    <div
                      role="tabpanel"
                      class="tab-content border-t-0 px-4 pt-5 pb-6 text-base font-normal sm:px-6"
                    >
                      {
                        descriptionRender ? (
                          <div class="prose-course">
                            <descriptionRender.Content />
                          </div>
                        ) : (
                          <p class="text-base-content/70">
                            Este curso aun no tiene contenido publicado. Puedes reservar una sesión
                            y un tutor te guiará con el material.
                          </p>
                        )
                      }
                    </div>
                    <input
                      type="radio"
                      name="course_tabs"
                      role="tab"
                      class="tab text-base font-bold tracking-tight"
                      aria-label="Contenidos del Curso"
                    />
                    <div
                      role="tabpanel"
                      class="tab-content border-t-0 px-4 pt-5 pb-6 text-base font-normal sm:px-6"
                    >
                      {
                        contentRender ? (
                          <div class="prose-course">
                            <contentRender.Content />
                          </div>
                        ) : (
                          <p class="text-base-content/70">
                            Este curso aun no tiene contenido publicado. Puedes reservar una sesión
                            y un tutor te guiará con el material.
                          </p>
                        )
                      }
                    </div>
                    <input
                      id="tab-sessions"
                      type="radio"
                      name="course_tabs"
                      role="tab"
                      class="tab text-base font-bold tracking-tight"
                      aria-label="Próximas Sesiones"
                    />
                    <div
                      role="tabpanel"
                      class="tab-content border-t-0 px-4 pt-5 pb-6 text-base font-normal sm:px-6"
                    >
                      <CourseSessionsTab
                        courseAcronym={course.acronym}
                        courseTitle={course.title}
                        client:load
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <aside class="md:sticky md:top-24 md:col-span-2 md:self-start">
            <CourseProfessorsSection
              courseAcronym={course.acronym}
              teamProfiles={teamProfilesPayload}
              client:load
            />
          </aside>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-8 pt-8 md:grid-cols-7">
          {
            relatedCourses.length > 0 && (
              <div class="card bg-base-100 shadow-xl md:col-span-5">
                <div class="card-body">
                  <h3 class="card-title text-base-content/70">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                      />
                    </svg>
                    Cursos Relacionados
                  </h3>
                  <div class="mt-4 flex flex-wrap gap-3">
                    {relatedCourses.map((relatedCourse) => (
                      <a
                        href={`/cursos/${relatedCourse.slug}`}
                        class="border-base-300 bg-base-100 block w-xs rounded-lg border p-3 shadow-md transition-colors hover:shadow-xl"
                      >
                        <div class="text-base-content/70 font-mono text-sm">
                          {relatedCourse.data.acronym}
                        </div>
                        <div class="line-clamp-2 font-medium">{relatedCourse.data.title}</div>
                        <div class="text-primary text-sm font-medium">
                          ${relatedCourse.data.basePrice.toLocaleString('es-CL')}
                        </div>
                      </a>
                    ))}
                  </div>
                  <div class="card-actions mt-2">
                    <a
                      href={`/cursos?department=${encodeURIComponent(course.department)}`}
                      class="btn btn-accent btn-sm"
                    >
                      Ver todos los cursos de {course.department}
                    </a>
                  </div>
                </div>
              </div>
            )
          }
          <div class={relatedCourses.length > 0 ? 'md:col-span-2' : ''}>
            <CourseHelpCard course={course} />
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tab-content {
    animation: fadeIn 0.3s ease-in-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
